# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
CORS_ORIGINS=["*"]

# --- Database ---
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://devcraft:secret@localhost:5432/devcraft

# --- Bot integration ---
# When set, new leads are POSTed here so the Telegram bot can notify admins.
# Example: BOT_NOTIFY_URL=http://bot:8080/internal/notify
BOT_NOTIFY_URL=
BOT_NOTIFY_TIMEOUT=5.0

# --- Security ---
ADMIN_TOKEN=change-me-in-prod

# --- Static site ---
SERVE_SITE=true
